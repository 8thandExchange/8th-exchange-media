{
  "name": "8th & Exchange Media",
  "version": "2.0",
  "color": {
    "navy":     { "value": "#0B1B3D", "rgb": "11,27,61",   "role": "primary / backgrounds / text" },
    "gold":     { "value": "#C5A059", "rgb": "197,160,89",  "role": "accent only — headlines, labels, dividers, MEDIA" },
    "goldDark": { "value": "#9C7A38", "rgb": "156,122,56",  "role": "gold labels on light (large only)" },
    "cream":    { "value": "#F4EFE3", "rgb": "244,239,227", "role": "light backgrounds / reversed text" },
    "paper":    { "value": "#FBF8F1", "rgb": "251,248,241", "role": "alternate light background" },
    "ink":      { "value": "#0A1424", "rgb": "10,20,36",    "role": "deepest navy / body text on cream" }
  },
  "font": {
    "display": "'Playfair Display',Georgia,serif",
    "body": "'Hanken Grotesk','Inter',sans-serif",
    "note": "Unified system: Playfair Display (coin, mastheads, headlines) + Hanken Grotesk (body, UI, labels). Both open-licensed via Google Fonts — no licensing to clear."
  },
  "typeScale": {
    "display": { "size": "clamp(2.6rem,6vw,4.2rem)", "weight": 600, "lineHeight": 1.02, "tracking": "-0.01em" },
    "h2":      { "size": "2rem",     "weight": 600, "lineHeight": 1.10, "tracking": "0" },
    "h3":      { "size": "1.25rem",  "weight": 600, "lineHeight": 1.30, "tracking": "0", "face": "body" },
    "lead":    { "size": "1.125rem", "weight": 400, "lineHeight": 1.60, "tracking": "0", "face": "body" },
    "body":    { "size": "1rem",     "weight": 400, "lineHeight": 1.65, "tracking": "0", "face": "body", "measure": "<=62ch" },
    "label":   { "size": "0.75rem",  "weight": 600, "lineHeight": 1.40, "tracking": "0.18em", "transform": "uppercase", "face": "body" },
    "button":  { "size": "0.8125rem","weight": 600, "tracking": "0.14em", "transform": "uppercase", "face": "body" }
  },
  "contrast": {
    "target": "7:1",
    "pairs": [
      { "pair": "navy/cream", "ratio": 14.8, "grade": "AAA", "use": "body anywhere" },
      { "pair": "ink/cream",  "ratio": 16.1, "grade": "AAA", "use": "densest body on light" },
      { "pair": "gold/ink",   "ratio": 7.5,  "grade": "AAA", "use": "gold on deepest navy" },
      { "pair": "gold/navy",  "ratio": 6.9,  "grade": "AA",  "use": "headlines, labels, accents — not long body" },
      { "pair": "goldDark/cream", "ratio": 3.5, "grade": "AA-large", "use": "small gold labels on light" },
      { "pair": "gold/cream", "ratio": 2.1,  "grade": "FAIL", "use": "never — do not set gold type on cream" }
    ]
  },
  "geometry": { "radius": "0", "rule": "1px", "maxWidth": "1120px" },
  "tailwind": {
    "colors": { "navy":"#0B1B3D","gold":"#C5A059","goldDark":"#9C7A38","cream":"#F4EFE3","paper":"#FBF8F1","ink":"#0A1424" },
    "fontFamily": { "display":["Playfair Display","serif"], "body":["Hanken Grotesk","Inter","sans-serif"] },
    "borderRadius": { "DEFAULT":"0" }
  }
}
