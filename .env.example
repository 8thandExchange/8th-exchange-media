# Invoicing environment variables

# Stripe (required)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Invoicing admin access (required)
INVOICING_ADMIN_PASSWORD=choose-a-strong-password

# Optional: separate signing secret for invoicing sessions
INVOICING_SESSION_SECRET=random-long-secret

# Invoice payment methods (comma-separated). ACH is listed first to prefer bank debit.
# Set to "dashboard" to use Stripe Billing invoice defaults instead.
INVOICING_PAYMENT_METHODS=us_bank_account,card

# Existing contact form
RESEND_API_KEY=
CONTACT_TO_EMAIL=media@8thandexchange.com
CONTACT_FROM_EMAIL=8th & Exchange Media <hello@8thandexchange.com>
